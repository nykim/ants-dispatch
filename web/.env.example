# Copy to .env.local for local dev; production build uses .env.production.
# Pull these from the CloudFormation outputs of the deployed stacks.

# API base — leave empty in prod (served same-origin via CloudFront /admin, /public).
# In dev we point straight at API Gateway (cross-origin, CORS already allows localhost:5173).
VITE_API_BASE=https://<apiId>.execute-api.us-east-1.amazonaws.com/dev

# Cognito Hosted UI (NdaDispatch-Dev-Auth outputs)
VITE_COGNITO_DOMAIN=nda-dispatch-dev-xxxx.auth.us-east-1.amazoncognito.com
VITE_COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx
VITE_COGNITO_REGION=us-east-1

# Where Cognito should redirect after login. Must match a callbackUrl on the
# User Pool client (auth-stack.ts registers localhost:5173 and the adminHost).
VITE_REDIRECT_URI=http://localhost:5173/auth/callback

# Brand prefix shown before "Dispatch" in the sidebar, browser tab title,
# and the collapsed-sidebar mark (uses the first letter). "Dispatch" stays
# fixed; only the prefix is configurable. Defaults to "MailAnts" if unset.
# Examples: NDA, Acme, Lab Notes.
# VITE_APP_BRAND=MailAnts

# Optional. Public Cloudflare Turnstile site key for the /subscribe form.
# Without it the form still works (honeypot + WAF rate-limit + double
# opt-in confirmation are still in place), but you'll want to set this
# before publishing the URL widely. Pair with `TURNSTILE_SECRET` on the
# SubscribeFn Lambda env (set in your shell before `cdk deploy`).
# VITE_TURNSTILE_SITE_KEY=0x4AAA...
