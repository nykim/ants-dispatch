{
  "name": "@ants-dispatch/infra",
  "version": "0.0.0",
  "private": true,
  "bin": {
    "infra": "bin/app.js"
  },
  "scripts": {
    "build": "tsc",
    "watch": "tsc -w",
    "synth": "npx cdk synth",
    "diff:dev": "npx cdk diff -c env=dev",
    "diff:prod": "npx cdk diff -c env=prod",
    "deploy:dev": "npx cdk deploy --all -c env=dev --require-approval never",
    "deploy:prod": "npx cdk deploy --all -c env=prod --require-approval broadening"
  },
  "dependencies": {
    "aws-cdk-lib": "^2.170.0",
    "constructs": "^10.3.0",
    "source-map-support": "^0.5.21"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.143",
    "@types/node": "^20.14.0",
    "aws-cdk": "^2.170.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.0"
  }
}
